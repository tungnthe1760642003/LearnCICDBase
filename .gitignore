## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leasePublic/
x64/
x86/
bld/
[Bb]in/
[Oo]bj/
[Log]s/

# Visual Studio 2015/2017 cache/options directory
.vs/
# Uncomment if you have tasks that create the project's static files in wwwroot
#wwwroot/

# MSTest test Results
[Tt]est[Rr]esults/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml

# Build results
[Dd]ebug/
[Rr]elease/
bin/
obj/

# Docker
.dockerignore
docker-compose.override.yml

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# Others
.DS_Store
.vscode/
.idea/
*.swp
*.bak
*.log
